      ],
      "id": "c934a282-46e5-4505-9a63-315d98701f37",
      "name": "Set Output Data"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const input = item.json.formatted_input;\n\n  // Replace $ delimiters and extra junk\n  let cleaned = input.replace(/\\$/g, ' ')\n                     .replace(/[^a-zA-Z0-9\\s:/().,-]/g, ' ')\n                     .replace(/\\s+/g, ' ')\n                     .trim();\n\n  // Optionally shorten repeated irrelevant text (just keeping date/time/amount lines)\n  const regex = /(\\d{2}\\/\\d{2}\\/\\d{2})\\s+(\\d{2}:\\d{2}:\\d{2}).*?(AMOUNT|AHOUNT|ANCUNT|AHOLNT|ANOUNT|ANGUNT|AMOUNTE?)\\s*[$:]?\\s*(\\d+\\.\\d{2})/gi;\n  \n  let matches = [];\n  let match;\n  while ((match = regex.exec(cleaned)) !== null) {\n    matches.push(`${match[1]} ${match[2]} - Amount $${match[4]} - EPS Car Park Payment`);\n  }\n\n  // Build OpenAI-friendly prompt\n  const prompt = `Extract structured data from the following list of EPS Car Park transactions:\\n\\n` +\n    matches.map((line, i) => `${i + 1}. ${line}`).join('\\n') +\n    `\\n\\nFormat:\\n[\\n  {\\n    \"date\": \"YYYY-MM-DD\",\\n    \"time\": \"HH:MM:SS\",\\n    \"transaction_type\": \"EPS Car Park Payment\",\\n    \"description\": \"EPS Car Park Payment\",\\n    \"amount\": \"-X.XX\"\\n  },\\n  ...\\n]`;\n\n  return {\n    json: {\n      prompt\n    }\n  };\n});\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        980,
        -40
      ],
      "id": "250133a0-4f57-44a0-99d3-dbfb52c685da",
      "name": "Data Cleaning"
    }

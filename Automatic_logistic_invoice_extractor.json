      "parameters": {
        "jsCode": "const pages = $json.pages;\nlet combinedMarkdown = \"\";\n\nfor (let page of pages) {\n  combinedMarkdown += page.markdown + \"\\n\\n\";\n}\n\nreturn [\n  {\n    json: {\n      formatted_input: combinedMarkdown.trim()\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        980,
        -400
      ],
      "id": "177569fc-f689-4f6f-bac7-8f2909e9db97",
      "name": "Combain Pages"
    },
    {
      "parameters": {
        "jsCode": "const base64Image = $json.pages[0].images[0].image_base64;\n\nreturn [\n  {\n    binary: {\n      data: {\n        data: base64Image.split(',')[1],\n        mimeType: 'image/jpeg',\n        fileName: 'ocr-page.jpg'\n      }\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        980,
        -260
      ],
      "id": "7a307246-cea8-4643-a40c-42d10991721f",
      "name": "Convert to Image"

          "assignments": [
            {
              "id": "ac3b56c0-bddb-46b5-8bac-f00f371c81e5",
              "name": "formatted_input",
              "value": "={{ $json.text }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
